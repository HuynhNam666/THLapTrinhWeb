@model _2380601390_HuynhVanNam.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<style>
    .detail-card {
        border-radius: 20px;
        overflow: hidden;
    }

    .detail-img {
        width: 100%;
        height: 420px;
        object-fit: cover;
    }

    .detail-title {
        font-size: 2rem;
        font-weight: 700;
        color: #0f172a;
    }

    .detail-price {
        color: #dc2626;
        font-size: 1.5rem;
        font-weight: 700;
    }

    .detail-box p {
        font-size: 1.05rem;
        margin-bottom: 14px;
    }
</style>

<div class="card detail-card p-3">
    <div class="row align-items-center">
        <div class="col-md-5">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/600x400" : Model.ImageUrl)"
                 class="detail-img rounded"
                 alt="@Model.Name" />
        </div>

        <div class="col-md-7 detail-box p-4">
            <h2 class="detail-title">@Model.Name</h2>

            <p class="text-muted">@Model.Description</p>

            <p>
                <i class="fa-solid fa-layer-group text-primary me-2"></i>
                <strong>Danh mục:</strong> @Model.Category?.Name
            </p>

            <p class="detail-price">
                <i class="fa-solid fa-money-check-dollar me-2"></i>@Model.Price.ToString("N0") VNĐ
            </p>

            <p>
                <i class="fa-solid fa-boxes-stacked text-success me-2"></i>
                <strong>Tồn kho:</strong> @Model.Stock
            </p>

            <div class="mt-4 d-flex gap-2">
                <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id"
                   class="btn btn-primary">
                    <i class="fa-solid fa-cart-plus me-1"></i>Thêm vào giỏ hàng
                </a>

                <a asp-controller="Products" asp-action="Index"
                   class="btn btn-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i>Quay lại
                </a>
            </div>
        </div>
    </div>
</div>