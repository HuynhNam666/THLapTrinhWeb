@using Microsoft.AspNetCore.Identity
@using _2380601390_HuynhVanNam.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);

    <li class="nav-item me-2">
        <span class="nav-link text-light">
            <i class="fa-solid fa-user me-1"></i>
            Xin chào, @(user?.FullName ?? user?.Email)
        </span>
    </li>
    <li class="nav-item">
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-outline-light btn-sm">
                <i class="fa-solid fa-right-from-bracket me-1"></i>Đăng xuất
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-light" asp-area="Identity" asp-page="/Account/Register">
            <i class="fa-solid fa-user-plus me-1"></i>Đăng ký
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-light" asp-area="Identity" asp-page="/Account/Login">
            <i class="fa-solid fa-right-to-bracket me-1"></i>Đăng nhập
        </a>
    </li>
}
</ul>