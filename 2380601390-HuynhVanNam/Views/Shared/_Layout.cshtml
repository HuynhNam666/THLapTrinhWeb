<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shop Mini</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* 🔥 Shopee style */
        .navbar-main {
            background: linear-gradient(180deg,#f53d2d,#f63);
        }

        .logo {
            font-weight: bold;
            font-size: 22px;
            color: white;
        }

        .search-box {
            width: 50%;
        }

        .cart-btn {
            font-size: 22px;
            color: white;
        }

        .nav-link {
            color: white !important;
        }

            .nav-link:hover {
                opacity: 0.8;
            }
    </style>
</head>
<body>

    <!-- 🔥 HEADER SHOPEE -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-main">
            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                    🛍 SHOP MINI
                </a>

                <!-- SEARCH -->
                <form class="d-flex search-box mx-3" method="get" asp-controller="Product" asp-action="Index">
                    <input class="form-control me-2" type="search" name="keyword" placeholder="Tìm sản phẩm...">
                    <button class="btn btn-light">Tìm</button>
                </form>

                <!-- MENU RIGHT -->
                <div class="d-flex align-items-center gap-3">

                    <!-- GIỎ HÀNG -->
                    <a href="/Cart" class="cart-btn">
                        🛒
                    </a>

                    <!-- LOGIN -->
                    <partial name="_LoginPartial" />

                </div>
            </div>
        </nav>

        <!-- MENU DƯỚI -->
        <div class="bg-white border-bottom">
            <div class="container d-flex gap-3 py-2">
                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                <a class="nav-link text-dark" href="#">Liên hệ</a>

                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link text-danger fw-bold" href="/Admin/Dashboard">Admin</a>
                }
            </div>
        </div>
    </header>

    <!-- CONTENT -->
    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="bg-light text-center mt-5 p-3">
        <p>© 2026 - Shop Mini - ASP.NET Core</p>
    </footer>

    <!-- SCRIPT -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.IsInRole("Admin"))
    {
        <a href="/Admin/Product" class="btn btn-danger">⚙ Quản lý sản phẩm</a>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>