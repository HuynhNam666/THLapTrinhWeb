<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Shop Sản Phẩm</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body style="background:#f5f5f5">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">

        <div class="container">

            <a class="navbar-brand d-flex align-items-center fw-bold"
               asp-controller="Product"
               asp-action="Index">

                <img src="~/images/logo.png"
                     style="height:40px;margin-right:10px;transition:0.3s;"
                     class="logo">

                SHOP MINI

            </a>

            <div class="navbar-nav">

                <a class="nav-link"
                   asp-controller="Product"
                   asp-action="Index">
                    Sản phẩm
                </a>

                <a class="nav-link"
                   asp-controller="Home"
                   asp-action="Privacy">
                    Privacy
                </a>

            </div>

        </div>

    </nav>

    <div class="container mt-4">

        @RenderBody()

    </div>

    

</body>
</html>