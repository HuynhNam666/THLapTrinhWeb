<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mini Shop</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>
        body {
            background: #f5f7fb;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar-custom {
            background: linear-gradient(90deg, #0f172a, #1e293b);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: #fff !important;
        }

        .navbar .nav-link {
            color: #e2e8f0 !important;
            font-weight: 500;
            transition: 0.3s;
        }

        .navbar .nav-link:hover {
            color: #38bdf8 !important;
        }

        .page-container {
            margin-top: 30px;
            margin-bottom: 40px;
        }

        .alert {
            border-radius: 12px;
        }

        .footer-mini {
            text-align: center;
            color: #64748b;
            font-size: 14px;
            padding: 20px 0 10px 0;
        }

        .btn {
            border-radius: 10px;
        }

        .card {
            border: none;
            border-radius: 18px;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-store me-2"></i>Mini Shop
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainMenu">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">
                                <i class="fa-solid fa-box-open me-1"></i>Sản phẩm
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping me-1"></i>Giỏ hàng
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Orders" asp-action="MyOrders">
                                    <i class="fa-solid fa-receipt me-1"></i>Đơn hàng của tôi
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="fa-solid fa-chart-line me-1"></i>Quản trị
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-area="Admin" asp-controller="Products" asp-action="Index">
                                    <i class="fa-solid fa-layer-group me-1"></i>QL Sản phẩm
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                                    <i class="fa-solid fa-file-invoice me-1"></i>QL Đơn hàng
                                </a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["Error"]
            </div>
        }

        @RenderBody()
    </div>

    <div class="footer-mini">
        <i class="fa-regular fa-copyright me-1"></i>2026 - Mini Shop
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>