@model IEnumerable<_2380601390_HuynhVanNam.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<h2>Đơn hàng của tôi</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">Bạn chưa có đơn hàng nào.</div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card mb-4">
            <div class="card-header">
                <strong>Mã đơn:</strong> #@order.Id
                |
                <strong>Ngày đặt:</strong> @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                |
                <strong>Tổng tiền:</strong> @order.TotalAmount.ToString("N0") VNĐ
            </div>
            <div class="card-body">
                <p><strong>Người nhận:</strong> @order.CustomerName</p>
                <p><strong>SĐT:</strong> @order.Phone</p>
                <p><strong>Địa chỉ:</strong> @order.Address</p>

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.OrderDetails)
                        {
                            <tr>
                                <td>@item.Product?.Name</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("N0")</td>
                                <td>@((item.UnitPrice * item.Quantity).ToString("N0"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}