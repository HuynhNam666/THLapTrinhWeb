@model List<_2380601390_HuynhVanNam.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    var total = Model.Sum(x => x.Price * x.Quantity);
}

<h2>Giỏ hàng</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">Giỏ hàng đang trống.</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
                <th width="150"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Price.ToString("N0")</td>
                    <td>
                        <form asp-action="UpdateQuantity" method="post" class="d-flex gap-2">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control" style="width:100px;" />
                            <button type="submit" class="btn btn-warning btn-sm">Cập nhật</button>
                        </form>
                    </td>
                    <td>@((item.Price * item.Quantity).ToString("N0"))</td>
                    <td>
                        <a asp-action="Remove" asp-route-id="@item.ProductId" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h4>Tổng tiền: @total.ToString("N0") VNĐ</h4>

    <div class="mt-3">
        <a asp-controller="Orders" asp-action="Checkout" class="btn btn-success">Đặt hàng</a>
        <a asp-action="Clear" class="btn btn-secondary">Xóa toàn bộ giỏ</a>
    </div>
}