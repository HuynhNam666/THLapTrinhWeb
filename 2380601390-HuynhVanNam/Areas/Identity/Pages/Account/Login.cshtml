@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-row">
            <div class="auth-left">
                <span class="auth-badge">Mini Shop</span>
                <h1 class="auth-title">Đăng nhập</h1>
                <p class="auth-subtitle">Chào mừng bạn quay lại, hãy đăng nhập để tiếp tục mua sắm.</p>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-group">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Mật khẩu" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-auth">Đăng nhập</button>

                    <div class="auth-links mt-3">
                        <div><a id="forgot-password" asp-page="./ForgotPassword">Quên mật khẩu?</a></div>
                        <div><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Tạo tài khoản mới</a></div>
                        <div><a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Gửi lại email xác nhận</a></div>
                    </div>
                </form>
            </div>

            <div class="auth-right">
                <div class="external-box">
                    <div class="icon-wrap">★</div>
                    <div class="auth-box">
                        <h3>Mua sắm nhanh hơn</h3>
                        <p>
                            Đăng nhập để theo dõi đơn hàng, lưu giỏ hàng và nhận ưu đãi dành riêng cho thành viên.
                        </p>

                        <ul class="feature-list">
                            <li>Theo dõi lịch sử mua hàng dễ dàng</li>
                            <li>Lưu thông tin giao hàng nhanh hơn</li>
                            <li>Nhận thông báo khuyến mãi mới nhất</li>
                        </ul>

                        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <hr />
                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mt-3">
                                <div>
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-outline-primary w-100 mb-2" name="provider" value="@provider.Name" title="Đăng nhập bằng @provider.DisplayName">
                                            Đăng nhập bằng @provider.DisplayName
                                        </button>
                                    }
                                </div>
                            </form>
                        }
                        else
                        {
                            <p class="mt-3 mb-0">
                                Đăng nhập bằng Google/Facebook sẽ sớm được hỗ trợ.
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}