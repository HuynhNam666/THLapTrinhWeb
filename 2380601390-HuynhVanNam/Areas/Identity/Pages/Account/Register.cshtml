@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-row">
            <div class="auth-left">
                <span class="auth-badge">Mini Shop</span>
                <h1 class="auth-title">Đăng ký</h1>
                <p class="auth-subtitle">Tạo tài khoản mới để bắt đầu trải nghiệm mua sắm tiện lợi hơn.</p>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-group">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-auth">Tạo tài khoản</button>

                    <div class="auth-links mt-3">
                        <div><a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Đã có tài khoản? Đăng nhập</a></div>
                    </div>
                </form>
            </div>

            <div class="auth-right">
                <div class="external-box">
                    <div class="icon-wrap">✓</div>
                    <div class="auth-box">
                        <h3>Tham gia Mini Shop</h3>
                        <p>
                            Tạo tài khoản để lưu thông tin cá nhân, quản lý đơn hàng và nhận nhiều ưu đãi hấp dẫn.
                        </p>

                        <ul class="feature-list">
                            <li>Đặt hàng nhanh và tiện lợi hơn</li>
                            <li>Dễ dàng kiểm tra trạng thái đơn hàng</li>
                            <li>Quản lý thông tin cá nhân tập trung</li>
                        </ul>

                        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <hr />
                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mt-3">
                                <div>
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-outline-primary w-100 mb-2" name="provider" value="@provider.Name" title="Đăng ký bằng @provider.DisplayName">
                                            Đăng ký bằng @provider.DisplayName
                                        </button>
                                    }
                                </div>
                            </form>
                        }
                        else
                        {
                            <p class="mt-3 mb-0">
                                Đăng ký nhanh bằng dịch vụ ngoài sẽ sớm được cập nhật.
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}