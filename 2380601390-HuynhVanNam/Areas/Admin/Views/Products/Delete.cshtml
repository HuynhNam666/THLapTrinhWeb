@model _2380601390_HuynhVanNam.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<h2>Xóa sản phẩm</h2>

<div class="alert alert-warning">
    Bạn có chắc muốn xóa sản phẩm này không?
</div>

<dl class="row">
    <dt class="col-sm-3">Tên sản phẩm</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Danh mục</dt>
    <dd class="col-sm-9">@Model.Category?.Name</dd>

    <dt class="col-sm-3">Giá</dt>
    <dd class="col-sm-9">@Model.Price.ToString("N0") VNĐ</dd>

    <dt class="col-sm-3">Tồn kho</dt>
    <dd class="col-sm-9">@Model.Stock</dd>
</dl>

<form asp-area="Admin" asp-controller="Products" asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>