@model _2380601390_HuynhVanNam.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<h2>Chi tiết sản phẩm</h2>

<div class="card p-3">
    <div class="row">
        <div class="col-md-4">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/300x200" : Model.ImageUrl)"
                 class="img-fluid rounded" />
        </div>
        <div class="col-md-8">
            <p><strong>ID:</strong> @Model.Id</p>
            <p><strong>Tên:</strong> @Model.Name</p>
            <p><strong>Mô tả:</strong> @Model.Description</p>
            <p><strong>Danh mục:</strong> @Model.Category?.Name</p>
            <p><strong>Giá:</strong> @Model.Price.ToString("N0") VNĐ</p>
            <p><strong>Tồn kho:</strong> @Model.Stock</p>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>