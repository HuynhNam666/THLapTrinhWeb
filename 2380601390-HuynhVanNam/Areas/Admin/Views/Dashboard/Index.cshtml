@model IEnumerable<_2380601390_HuynhVanNam.Models.Product>

<h2>Danh sách sản phẩm</h2>

<a href="/Admin/Product/Create">Thêm mới</a>

<table class="table">
    <tr>
        <th>Tên</th>
        <th>Giá</th>
        <th>Ảnh</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td><img src="@item.ImageUrl" width="80" /></td>
            <td>
                <a href="/Admin/Product/Edit/@item.Id">Sửa</a> |
                <a href="/Admin/Product/Delete/@item.Id">Xóa</a>
            </td>
        </tr>
    }
</table>