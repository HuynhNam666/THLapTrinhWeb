@{
    ViewData["Title"] = "Trang quản trị";
}

<h2>Trang quản trị</h2>

<div class="mb-3">
    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-primary">
        Quản lý sản phẩm
    </a>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card p-3">
            <h4>Tổng sản phẩm</h4>
            <h2>@ViewBag.TotalProducts</h2>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card p-3">
            <h4>Tổng đơn hàng</h4>
            <h2>@ViewBag.TotalOrders</h2>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card p-3">
            <h4>Doanh thu</h4>
            <h2>@(((decimal)ViewBag.TotalRevenue).ToString("N0")) VNĐ</h2>
        </div>
    </div>
</div>