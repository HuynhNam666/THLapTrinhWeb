@model _2380601390_HuynhVanNam.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<h2>Chi tiết đơn hàng #@Model.Id</h2>

<div class="card p-3 mb-3">
    <p><strong>Tài khoản đặt hàng:</strong> @(Model.User?.FullName ?? "Không có")</p>
    <p><strong>Email:</strong> @Model.User?.Email</p>
    <p><strong>Người nhận:</strong> @Model.CustomerName</p>
    <p><strong>Số điện thoại:</strong> @Model.Phone</p>
    <p><strong>Địa chỉ:</strong> @Model.Address</p>
    <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
    <p><strong>Tổng tiền:</strong> @Model.TotalAmount.ToString("N0") VNĐ</p>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.OrderDetails)
    {
        <tr>
            <td>@item.Product?.Name</td>
            <td>@item.Quantity</td>
            <td>@item.UnitPrice.ToString("N0")</td>
            <td>@((item.UnitPrice * item.Quantity).ToString("N0"))</td>
        </tr>
    }
    </tbody>
</table>

<a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-secondary">Quay lại</a>