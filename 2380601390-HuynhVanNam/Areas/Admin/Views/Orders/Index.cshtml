@model IEnumerable<_2380601390_HuynhVanNam.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<h2>Quản lý đơn hàng</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Mã đơn</th>
            <th>Người đặt</th>
            <th>Email tài khoản</th>
            <th>Người nhận</th>
            <th>SĐT</th>
            <th>Ngày đặt</th>
            <th>Tổng tiền</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>#@item.Id</td>
            <td>@(item.User?.FullName ?? "Chưa có")</td>
            <td>@item.User?.Email</td>
            <td>@item.CustomerName</td>
            <td>@item.Phone</td>
            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@item.TotalAmount.ToString("N0") VNĐ</td>
            <td>
                <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                    Chi tiết
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>