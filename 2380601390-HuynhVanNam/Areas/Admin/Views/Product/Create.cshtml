@model _2380601390_HuynhVanNam.Models.Product

<h2>Thêm sản phẩm</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <input asp-for="Name" class="form-control mb-2" placeholder="Tên" />
    <input asp-for="Price" class="form-control mb-2" placeholder="Giá" />

    <select asp-for="CategoryId" class="form-control mb-2">
        @foreach (var c in ViewBag.Categories)
        {
            <option value="@c.Id">@c.Name</option>
        }
    </select>

    <input type="file" name="imageFile" class="form-control mb-2" />

    <button class="btn btn-primary">Lưu</button>
</form>