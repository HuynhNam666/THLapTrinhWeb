@model IEnumerable<_2380601390_HuynhVanNam.Models.Product>

<h2>Quản lý sản phẩm</h2>

<a href="/Admin/Product/Create" class="btn btn-success mb-2">➕ Thêm sản phẩm</a>

<table class="table table-bordered">
    <tr>
        <th>Tên</th>
        <th>Giá</th>
        <th>Ảnh</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td><img src="@item.ImageUrl" width="80" /></td>
            <td>
                <a href="/Admin/Product/Edit/@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                <a href="/Admin/Product/Delete/@item.Id" class="btn btn-danger btn-sm">Xoá</a>
            </td>
        </tr>
    }
</table>